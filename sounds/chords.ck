public class Chords {
    // you will realize that counting keyboard from 0 (root) to 3 results in the minor 3rd
    [0, 3, 7] @=> static int minor[];
    [0, 4, 7] @=> static int major[];
    [0, 5, 7] @=> static int sus4[];
    [0, 2, 7] @=> static int sus2[];
    [0, 4, 7, 10] @=> static int dom7[];
    [0, 4, 7, 11] @=> static int maj7[];
    [0, 3, 7, 10] @=> static int min7[];
    [0, 5, 7, 10] @=> static int sus47[];
    [0, 3, 7, 13] @=> static int min79[];
}
